DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/dbname
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_DB=dbname

# Redis 
REDIS_URL=redis://redis:6379

# JWT Auth
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# LLM APIs
GROQ_API_KEY=gsk_...         # https://console.groq.com 
GEMINI_API_KEY=...            # https://aistudio.google.com/apikey 

# LLM model settings (optional — defaults shown)
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# Guardrails — token budgets (optional — defaults shown)
DAILY_TOKEN_BUDGET=100000     # total tokens/day across all interviews
SESSION_TOKEN_BUDGET=15000    # tokens per interview session

# Jina embeddings
JINA_API_KEY=...
